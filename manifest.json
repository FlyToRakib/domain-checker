{
  "manifest_version": 3,
  "name": "Domain Availability Checker - Bulk Search",
  "short_name": "Domain Checker",
  "version": "1.1.0",
  "description": "Bulk domain availability checker for investors. Scan multiple TLDs fast via RDAP API and live registrar scraping. 100% private and local-first.",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://rdap.org/*",
    "https://www.hostinger.com/*",
    "https://www.namecheap.com/*",
    "https://www.godaddy.com/*"
  ]
}